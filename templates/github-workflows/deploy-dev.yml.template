name: Terraform Deploy (dev)

on:
  push:
    branches: [dev]
  workflow_dispatch:

permissions:
  id-token: write
  contents: read

jobs:
  deploy:
    uses: __CICD_REPO_SLUG__/.github/workflows/reusable-terraform-deploy.yml@__CICD_REPO_REF__
    with:
      project_name: __PROJECT_NAME__
      tf_env_dir: infra/terraform/envs/dev
      aws_region: __AWS_REGION__
      branch_env: dev
    secrets:
      aws_role_arn: ${{ secrets.AWS_ROLE_ARN_DEV }}
